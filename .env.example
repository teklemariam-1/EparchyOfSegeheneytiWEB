# ─────────────────────────────────────────────
# Eparchy of Segeneyti — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URI=postgresql://postgres:password@localhost:5432/eparchy_segeneyti

# ── Payload CMS ──────────────────────────────
# Must be a strong random string (min 32 chars)
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ── Next.js ───────────────────────────────────
# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Media / File Storage ─────────────────────
# Set STORAGE_ADAPTER to 'local' (dev) or 's3' (production)
STORAGE_ADAPTER=local

# S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
# Only required when STORAGE_ADAPTER=s3
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_HOSTNAME=pub-<id>.r2.dev

# ── Email (Nodemailer / Resend / SendGrid) ────
# Used by Payload for password reset emails, form notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@segeneyti.org
SMTP_PASS=
SMTP_FROM="Eparchy of Segeneyti <noreply@segeneyti.org>"

# Contact form notification recipient
CONTACT_NOTIFICATION_EMAIL=chancery@segeneyti.org

# ── Analytics (optional) ─────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Feature Flags ─────────────────────────────
# Enable/disable multilingual support
NEXT_PUBLIC_ENABLE_TIGRINYA=true
NEXT_PUBLIC_ENABLE_ARABIC=false
