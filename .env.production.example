# ─────────────────────────────────────────────────────────────────────────────
# Eparchy of Segeneyti — PRODUCTION Environment Variables
# Copy to .env.production.local on the server and fill in every value.
# NEVER commit this file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (running on the same server via Unix socket for best performance)
DATABASE_URI=postgresql://eparchy:STRONG_DB_PASSWORD@localhost:5432/eparchy_segeneyti

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
PAYLOAD_SECRET=CHANGE_THIS_TO_A_CRYPTOGRAPHICALLY_STRONG_48_CHAR_SECRET

# ── Next.js public URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.segeneyti.org

# ── Media / File Storage ──────────────────────────────────────────────────────
STORAGE_ADAPTER=s3

# Cloudflare R2 (or AWS S3) — all values required when STORAGE_ADAPTER=s3
S3_BUCKET=eparchy-media
S3_REGION=auto
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
# Public CDN hostname for the R2 bucket (used for Next.js image optimisation)
S3_HOSTNAME=pub-<id>.r2.dev

# ── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.segeneyti.org
SMTP_PORT=465
SMTP_USER=noreply@segeneyti.org
SMTP_PASS=<SMTP_PASSWORD>
SMTP_FROM="Eparchy of Segeneyti <noreply@segeneyti.org>"

# Contact form notification recipient
CONTACT_NOTIFICATION_EMAIL=chancery@segeneyti.org

# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (leave empty to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TIGRINYA=true

# ── Node.js runtime ──────────────────────────────────────────────────────────
NODE_ENV=production
# Port the Next.js server listens on (Nginx proxies to this)
PORT=3000
